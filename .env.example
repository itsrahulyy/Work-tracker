# Email
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_app_password
EMAIL_FROM=your_email@example.com
EMAIL_TO=person1@example.com,person2@example.com

# App timezone
APP_TIMEZONE=Asia/Calcutta

# Google Sheets
GOOGLE_WORK_SHEET_ID=your_work_sheet_id
GOOGLE_VIDEO_SHEET_ID=your_video_sheet_id
GOOGLE_VIDEO_SHEET_GID=your_video_sheet_gid

# Telegram (legacy keys kept for compatibility if you still use them elsewhere)
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_ANIRUDH=anirudh_chat_id
TELEGRAM_SAKSHI=sakshi_chat_id
TELEGRAM_PREM=prem_chat_id
TELEGRAM_SONALI=sonali_chat_id
TELEGRAM_RAHUL=rahul_chat_id

# WATI
WATI_API_URL=https://live-mt-server.wati.io/your-tenant/api/v1
WATI_API_TOKEN=your_wati_api_token
DIRECT_MSG_API_ENDPOINT=/sendSessionMessage
WATI_TEMPLATE_API_ENDPOINT=/api/v2/sendTemplateMessage
SCHEDULE_MSG_API_ENDPOINT=/broadcast/scheduleBroadcast
WATI_TEMPLATE_REMINDER_1=work_update
WATI_TEMPLATE_REMINDER_2=optional_template_name

# Team phone numbers
WATI_ANIRUDH=919876500001
